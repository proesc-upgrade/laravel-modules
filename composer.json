{
    "name": "creolab/laravel-modules",
    "keywords": ["modules", "laravel"],
    "description": "Application specific modules for Laravel 9+",
    "homepage": "http://creolab.hr",
    "license": "MIT",
    "authors": [
        {
            "name": "Boris Strahija",
            "email": "bstrahija@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0.2",
        "laravel/framework": "^9.0|^10.0|^11.0|^12.0"
    },
    "suggest": {
        "way/generators": "Legacy: required only for modules:generate (generate:* commands). Prefer php artisan make:* in modern Laravel."
    },
    "autoload": {
        "psr-4": {
            "Creolab\\LaravelModules\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Creolab\\LaravelModules\\ServiceProvider"
            ]
        }
    }
}
